<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="24"
    android:viewportHeight="24">

    <!-- 1. Deep background glow -->
    <path
        android:pathData="M12,12m-9.5,0a9.5,9.5 0,1 1,19 0a9.5,9.5 0,1 1,-19 0">
        <aapt:attr name="android:fillColor">
            <gradient
                android:centerX="12"
                android:centerY="12"
                android:gradientRadius="9.5"
                android:type="radial">
                <item android:offset="0.0" android:color="#3500D2FF" />
                <item android:offset="0.7" android:color="#0800E676" />
                <item android:offset="1.0" android:color="#00000000" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- 2. First swirling wave loop (Teal to Blue) -->
    <path
        android:pathData="M12,3.5 C16.69,3.5 20.5,7.31 20.5,12 C20.5,14.5 19.3,16.8 17.5,18.3 C16.2,14.2 12.8,11.2 8.5,10.2 C9.8,6.3 12,3.5 12,3.5 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:startX="12"
                android:startY="3.5"
                android:endX="17.5"
                android:endY="18.3"
                android:type="linear">
                <item android:offset="0.0" android:color="#00F5D4" /> <!-- Mint Teal -->
                <item android:offset="1.0" android:color="#00B0FF" /> <!-- Cyan Blue -->
            </gradient>
        </aapt:attr>
    </path>

    <!-- 3. Second swirling wave loop (Green to Teal) -->
    <path
        android:pathData="M12,20.5 C7.31,20.5 3.5,16.69 3.5,12 C3.5,9.5 4.7,7.2 6.5,5.7 C7.8,9.8 11.2,12.8 15.5,13.8 C14.2,17.7 12,20.5 12,20.5 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:startX="12"
                android:startY="20.5"
                android:endX="6.5"
                android:endY="5.7"
                android:type="linear">
                <item android:offset="0.0" android:color="#00E676" /> <!-- Neon Green -->
                <item android:offset="1.0" android:color="#00F5D4" /> <!-- Mint Teal -->
            </gradient>
        </aapt:attr>
    </path>

    <!-- 4. Overlapping glowing center core (Deep Radial glow) -->
    <path
        android:pathData="M12,12m-4.2,0a4.2,4.2 0,1 1,8.4 0a4.2,4.2 0,1 1,-8.4 0">
        <aapt:attr name="android:fillColor">
            <gradient
                android:centerX="12"
                android:centerY="12"
                android:gradientRadius="4.2"
                android:type="radial">
                <item android:offset="0.0" android:color="#FFF1F5F9" /> <!-- White hot center -->
                <item android:offset="0.4" android:color="#FF80DEEA" /> <!-- Cyan glow -->
                <item android:offset="1.0" android:color="#0000D2FF" /> <!-- Transparent edge -->
            </gradient>
        </aapt:attr>
    </path>

    <!-- 5. Fine boundary orbital overlay (Translucent white ring) -->
    <path
        android:strokeColor="#18FFFFFF"
        android:strokeWidth="0.4"
        android:fillColor="#00000000"
        android:pathData="M12,12m-10.5,0a10.5,10.5 0,1 1,21 0a10.5,10.5 0,1 1,-21 0" />

</vector>
